{
  "expo": {
    "name": "meettime",
    "slug": "meettime",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "meettime",
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c7e155c6-cf10-4c61-88bd-7abc32627648"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.meettime",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-notifications",
      "expo-sharing",
      [
        "expo-camera",
        {
          "cameraPermission": "MeetTime uses the camera to scan a friend's QR code."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MeetTime uses your photos for covers, the board, and your profile.",
          "cameraPermission": "MeetTime uses the camera to snap photos for your meetups."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c7e155c6-cf10-4c61-88bd-7abc32627648"
      }
    },
    "owner": "norbertbodziony"
  }
}
