{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_CONVEX_URL": "https://quixotic-llama-610.convex.cloud",
        "EXPO_PUBLIC_CONVEX_SITE_URL": "https://quixotic-llama-610.convex.site"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_CONVEX_URL": "https://quixotic-llama-610.convex.cloud",
        "EXPO_PUBLIC_CONVEX_SITE_URL": "https://quixotic-llama-610.convex.site"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
